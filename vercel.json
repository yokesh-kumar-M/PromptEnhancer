{
  "version": 2,
  "framework": null,
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "prompt_enhancer_backend/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "prompt_enhancer_backend/wsgi.py"
    }
  ],
  "env": {
    "DEBUG": "False",
    "CORS_ALLOW_ALL_ORIGINS": "True",
    "ALLOWED_HOSTS": ".vercel.app"
  }
}
